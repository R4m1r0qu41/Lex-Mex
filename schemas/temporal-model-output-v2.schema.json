{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lex-mex.local/schemas/temporal-model-output-v2.schema.json",
  "title": "Lex-Mex temporal provision and transitory-effect output batch v2",
  "type": "object",
  "required": ["determinations"],
  "properties": {
    "determinations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "provision_id",
          "temporal_status",
          "effective_from",
          "effective_to",
          "confidence",
          "supporting_text",
          "effects"
        ],
        "properties": {
          "provision_id": {
            "type": "string",
            "description": "Copy the supplied evidence provision_id exactly."
          },
          "temporal_status": {
            "type": "string",
            "enum": [
              "unknown",
              "published_not_effective",
              "effective",
              "future_effective",
              "repealed",
              "superseded"
            ],
            "description": "Status of the transitory provision itself, not the legal effect it creates."
          },
          "effective_from": {
            "type": ["string", "null"],
            "description": "ISO 8601 date on which the transitory itself became effective, or null."
          },
          "effective_to": {
            "type": ["string", "null"],
            "description": "ISO 8601 date on which the transitory itself ceased to be effective, or null."
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "supporting_text": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "description": "Exact verbatim substrings copied from the evidence text."
          },
          "effects": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/effect" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "boundary": {
      "type": "object",
      "required": ["boundary_type", "date", "description"],
      "properties": {
        "boundary_type": {
          "type": "string",
          "enum": [
            "none",
            "publication",
            "effective_date",
            "fixed_date",
            "relative_period",
            "external_event",
            "cohort_exhaustion",
            "authority_action",
            "unknown"
          ]
        },
        "date": {
          "type": ["string", "null"],
          "description": "ISO 8601 date when the source establishes or permits calculation of one."
        },
        "description": {
          "type": ["string", "null"],
          "description": "Concise description of a relative, event-based, authority-based, cohort, or unknown boundary."
        }
      },
      "additionalProperties": false
    },
    "effect": {
      "type": "object",
      "required": [
        "effect_type",
        "affected_scope",
        "application_rule",
        "trigger",
        "end_condition",
        "responsible_authorities",
        "verification_status"
      ],
      "properties": {
        "effect_type": {
          "type": "string",
          "enum": [
            "commencement",
            "implementation_deadline",
            "regulatory_deadline",
            "adaptation_period",
            "transitional_permission",
            "procedural_survival",
            "migration",
            "authority_assignment",
            "coordination_mandate",
            "staged_commencement",
            "sunset",
            "repeal",
            "other"
          ]
        },
        "affected_scope": {
          "type": "string",
          "minLength": 1,
          "description": "Concise description of the affected acts, persons, procedures, rules, or authorities."
        },
        "application_rule": {
          "type": "string",
          "enum": [
            "not_applicable",
            "new_rule_prospectively",
            "prior_rule_for_existing_matters",
            "transitional_permission",
            "migration_to_new_rule",
            "mixed",
            "unknown"
          ]
        },
        "trigger": { "$ref": "#/$defs/boundary" },
        "end_condition": { "$ref": "#/$defs/boundary" },
        "responsible_authorities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "verification_status": {
          "type": "string",
          "enum": [
            "not_required",
            "confirmed_by_source_text",
            "external_verification_required",
            "open_ended_by_design",
            "unknown_material"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
