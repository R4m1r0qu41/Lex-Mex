{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lex-mex.invalid/schemas/batch-manifest.schema.json",
  "title": "Lex-Mex batch-ingestion manifest",
  "description": "A batch of instruments to ingest through the deterministic pipeline. Folded from the retired vault tooling's import manifests; consumed by adapter scaffolding and `batch run`.",
  "type": "object",
  "required": ["schema_version", "batch_id", "description", "instruments"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "batch_id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "description": { "type": "string" },
    "notes": { "type": "array", "items": { "type": "string" } },
    "blocked": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "title", "reason"],
        "additionalProperties": false,
        "properties": {
          "slug": { "type": "string" },
          "title": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "instruments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slug", "title", "type", "adapter", "status", "source_pdf"],
        "additionalProperties": false,
        "properties": {
          "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "short_name": {
            "type": "string",
            "description": "Explicit canonical short name when it differs from the uppercased slug (e.g. CCom, LAmp)."
          },
          "title": { "type": "string" },
          "type": { "enum": ["ley", "codigo", "reglamento", "dcg"] },
          "adapter": { "enum": ["diputados", "cnbv"] },
          "status": { "enum": ["NEW"] },
          "ref_page": { "type": "string", "format": "uri" },
          "source_pdf": { "type": "string", "format": "uri" },
          "publisher": { "type": "string" },
          "role": { "enum": ["hub", "peer", "regulation", "bridge"] },
          "parent_law": { "type": "string" }
        }
      }
    },
    "expected_edges": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Analyst-predicted cross-reference recall expectations. Concrete entries use SOURCE -> TARGET or SOURCE articulo N -> TARGET, naming committed corpus slugs or short names. Unavailable targets are reported as deferred; missing or malformed concrete expectations fail batch closure."
    }
  }
}
