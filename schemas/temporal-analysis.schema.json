{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lex-mex.local/schemas/temporal-analysis.schema.json",
  "title": "Lex-Mex temporal determination",
  "type": "object",
  "required": [
    "provision_id",
    "temporal_status",
    "publication_date",
    "effective_from",
    "effective_to",
    "confidence",
    "basis",
    "supporting_text",
    "review_required",
    "review_reason",
    "model",
    "prompt_version"
  ],
  "properties": {
    "provision_id": { "type": "string", "pattern": "^urn:lex-mx:" },
    "temporal_status": {
      "enum": [
        "unknown",
        "published_not_effective",
        "effective",
        "future_effective",
        "partially_effective",
        "conditionally_effective",
        "repealed",
        "repealed_with_survival",
        "superseded",
        "temporarily_applicable",
        "pending_consolidation"
      ]
    },
    "publication_date": { "type": "string", "format": "date" },
    "effective_from": { "type": ["string", "null"], "format": "date" },
    "effective_to": { "type": ["string", "null"], "format": "date" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "basis": { "const": "llm_inference" },
    "supporting_text": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "review_required": { "type": "boolean" },
    "review_reason": { "type": ["string", "null"] },
    "model": { "type": "string", "minLength": 1 },
    "prompt_version": { "const": "temporal-v1" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "confidence": { "exclusiveMaximum": 0.92 }
        }
      },
      "then": {
        "properties": {
          "review_required": { "const": true },
          "review_reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "temporal_status": {
            "enum": ["partially_effective", "conditionally_effective"]
          }
        }
      },
      "then": {
        "properties": {
          "review_required": { "const": true },
          "review_reason": { "type": "string", "minLength": 1 }
        }
      }
    }
  ],
  "additionalProperties": false
}

