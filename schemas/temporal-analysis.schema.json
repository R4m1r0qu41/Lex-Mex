{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lex-mex.local/schemas/temporal-analysis.schema.json",
  "title": "Lex-Mex canonical temporal determination v2",
  "type": "object",
  "required": [
    "provision_id",
    "temporal_status",
    "publication_date",
    "effective_from",
    "effective_to",
    "confidence",
    "basis",
    "supporting_text",
    "review_required",
    "review_reason",
    "model",
    "prompt_version",
    "effects"
  ],
  "properties": {
    "provision_id": { "type": "string", "pattern": "^urn:lex-mx:" },
    "temporal_status": {
      "enum": [
        "unknown",
        "published_not_effective",
        "effective",
        "future_effective",
        "repealed",
        "superseded"
      ]
    },
    "publication_date": { "type": "string", "format": "date" },
    "effective_from": { "type": ["string", "null"], "format": "date" },
    "effective_to": { "type": ["string", "null"], "format": "date" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "basis": { "enum": ["llm_inference", "lawyer_verified"] },
    "supporting_text": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "review_required": { "type": "boolean" },
    "review_reason": { "type": ["string", "null"] },
    "model": { "type": "string", "minLength": 1 },
    "prompt_version": { "type": "string", "minLength": 1 },
    "effects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "temporal-model-output-v2.schema.json#/$defs/effect"
      }
    }
  },
  "additionalProperties": false
}
