{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lex-mex.local/schemas/temporal-analysis.schema.json",
  "title": "Lex-Mex canonical temporal determination v2",
  "type": "object",
  "required": [
    "provision_id",
    "temporal_status",
    "publication_date",
    "effective_from",
    "effective_to",
    "confidence",
    "basis",
    "supporting_text",
    "review_required",
    "review_reason",
    "model",
    "prompt_version",
    "effects"
  ],
  "properties": {
    "provision_id": { "type": "string", "pattern": "^urn:lex-mx:" },
    "temporal_status": {
      "enum": [
        "unknown",
        "published_not_effective",
        "effective",
        "future_effective",
        "repealed",
        "superseded"
      ]
    },
    "publication_date": { "type": "string", "format": "date" },
    "effective_from": { "type": ["string", "null"], "format": "date" },
    "effective_to": { "type": ["string", "null"], "format": "date" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "basis": { "enum": ["llm_inference", "lawyer_verified"] },
    "supporting_text": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "review_required": { "type": "boolean" },
    "review_reason": { "type": ["string", "null"] },
    "model": { "type": "string", "minLength": 1 },
    "prompt_version": { "type": "string", "minLength": 1 },
    "effects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/canonical_effect"
      }
    }
  },
  "$defs": {
    "canonical_effect": {
      "type": "object",
      "required": [
        "effect_type",
        "affected_scope",
        "application_rule",
        "trigger",
        "end_condition",
        "responsible_authorities",
        "verification_status"
      ],
      "properties": {
        "effect_type": {
          "type": "string",
          "enum": [
            "commencement",
            "implementation_deadline",
            "regulatory_deadline",
            "adaptation_period",
            "transitional_permission",
            "procedural_survival",
            "migration",
            "authority_assignment",
            "coordination_mandate",
            "staged_commencement",
            "sunset",
            "repeal",
            "other"
          ]
        },
        "affected_scope": { "type": "string", "minLength": 1 },
        "application_rule": {
          "type": "string",
          "enum": [
            "not_applicable",
            "new_rule_prospectively",
            "prior_rule_for_existing_matters",
            "transitional_permission",
            "migration_to_new_rule",
            "mixed",
            "unknown"
          ]
        },
        "trigger": {
          "$ref": "temporal-model-output-v2.schema.json#/$defs/boundary"
        },
        "end_condition": {
          "$ref": "temporal-model-output-v2.schema.json#/$defs/boundary"
        },
        "responsible_authorities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "verification_status": {
          "type": "string",
          "enum": [
            "not_required",
            "confirmed_by_source_text",
            "external_verification_required",
            "externally_verified",
            "open_ended_by_design",
            "unknown_material"
          ]
        },
        "verification_source_url": {
          "type": ["string", "null"],
          "format": "uri"
        },
        "verified_event_date": {
          "type": ["string", "null"],
          "format": "date"
        },
        "verification_note": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
